{
  "name": "runway",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "electron:build": "tsc -b && vite build && electron-builder",
    "electron:build:mac": "tsc -b && vite build && electron-builder --mac",
    "electron:build:win": "tsc -b && vite build && electron-builder --win",
    "electron:build:all": "tsc -b && vite build && electron-builder --mac --win",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:web": "DEPLOY_TARGET=ghpages tsc -b && DEPLOY_TARGET=ghpages vite build",
    "deploy": "npm run build:web && gh-pages -d dist",
    "release": "bash scripts/release.sh"
  },
  "build": {
    "appId": "com.runway.todo-gantt",
    "productName": "Runway",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": null,
      "uninstallerIcon": null,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "date-fns": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "gh-pages": "^6.3.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.4",
    "wait-on": "^9.0.4"
  }
}
